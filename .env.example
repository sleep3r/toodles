# ──────────────────────────────────────────────────────────────────────────────
# Toodles – .env example
# Copy this file to .env and fill in the values before running the bot.
# ──────────────────────────────────────────────────────────────────────────────

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCDefGhIJKlmNoPQRsTUVwxyZ

# Optional: comma-separated list of Telegram user IDs that may use the bot.
# Leave empty (or remove the line) to allow anyone.
ALLOWED_USER_IDS=123456789,987654321

# Optional: path to the gemini-cli binary (default: "gemini").
# Set this if the binary is not on your PATH or has a different name.
GEMINI_CLI_PATH=gemini

# Optional: full ACP command for legacy gemini profile.
# If unset, toodles uses: "${GEMINI_CLI_PATH} --acp"
# GEMINI_CLI_COMMAND=gemini --acp

# Optional: working directory for gemini-cli sessions.
# Useful if you want Gemini to have access to a specific project directory.
# GEMINI_WORKING_DIR=/home/user/my-project

# Optional: enable/disable ACP yolo mode (auto-approve).
# GEMINI_YOLO=true

# Optional: draft UI verbosity during streaming responses.
# compact = minimal waiting text
# verbose = waiting + structured progress log
# DRAFT_MODE=verbose

# Optional: auto-rename forum topic every N user messages in the topic.
# Set 0 to disable auto-renaming.
# The first user message in a topic always sets the initial title.
# THREAD_RENAME_EVERY=4

# Optional: keep N idle prewarmed ACP sessions for faster first reply.
# Set 0 to disable warm pool.
# WARM_SESSION_POOL_SIZE=1

# Optional: read additional settings from ~/.config/toodles/config.toml
# TOODLES_CONFIG=~/.config/toodles/config.toml

# Optional: OpenAI API key for Whisper voice transcription.
# Without this key, voice messages will not be forwarded to Gemini.
# OPENAI_API_KEY=sk-...

# Optional: system prompt prepended to the first query in each session.
# Customize the bot's personality and behavior.
# SYSTEM_PROMPT=You are a helpful AI assistant. Keep answers concise.

# Optional: log level (default: "info").
# RUST_LOG=debug
